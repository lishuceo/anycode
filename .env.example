# === 飞书应用配置 ===
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=              # 事件加密 Key (可选，推荐配置)
FEISHU_VERIFY_TOKEN=             # 事件验证 Token

# === 安全配置 ===
# 允许使用的飞书用户 open_id 列表，逗号分隔。为空则允许所有用户
ALLOWED_USER_IDS=

# === Claude Code 配置 ===
# Anthropic API Key (Claude Code 需要)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# 默认工作目录
DEFAULT_WORK_DIR=/home/ubuntu/projects
# 单次执行超时时间(秒)
CLAUDE_TIMEOUT=300

# === 服务配置 ===
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
