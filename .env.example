# === 飞书配置 ===
# 飞书应用凭证 (appId/appSecret) 已迁移到 config/agents.json 的 agent.feishu 字段
# 运行 npm run onboard 自动配置，或手动编辑 config/agents.json

# 事件接收模式 (默认 websocket，推荐):
#   websocket - 长连接，无需公网/域名/HTTPS，SDK 主动连接飞书
#   webhook   - HTTP 回调，需要公网 HTTPS 地址 (生产环境可选)
FEISHU_EVENT_MODE=websocket

# 以下仅 webhook 模式需要，websocket 模式可留空
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFY_TOKEN=

# === 安全配置 ===
# 免审批白名单：这些用户可直接使用 bot，无需管理员审批
# 逗号分隔的飞书 open_id。为空则所有人免审批（由 OWNER_USER_ID 控制审批逻辑）
# 不在白名单中的用户会触发审批流程（而非直接拒绝）
ALLOWED_USER_IDS=
# 管理员用户 open_id，拥有完整代码编辑权限，负责审批非白名单用户
# 为空时自动将首个发消息的用户设为管理员
OWNER_USER_ID=

# === Session Fork 配置 (Plan 8) ===
# /fork 命令开关,默认开启。设为 false 可关闭
# FORK_ENABLED=false

# === Claude Code 配置 ===
# Anthropic API Key (Claude Code 需要)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Anthropic API Base URL (可选，用于代理或自定义端点，留空使用官方地址)
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# 项目目录（通常无需配置 — 默认为本仓库的父目录，即 process.cwd() 的上一级）
# DEFAULT_WORK_DIR=/root/dev
# 单步空闲超时(秒)：某步骤长时间无 SDK 消息活动时 abort，不限制总执行时长
CLAUDE_TIMEOUT=300
# 工具执行硬顶(秒)：单个工具持续执行超过此时长才视为挂死。默认 900，高于 SDK 单条 Bash 上限(600s)
# 防止长工具(编译/批处理/克隆大仓)被 idle 超时误杀
CLAUDE_TOOL_TIMEOUT=900
# Codex reviewer 开关 (pipeline review 阶段使用 OpenAI Codex，默认关闭)
# CODEX_ENABLED=false

# === 飞书 OAuth 用户授权 ===
# OAuth 回调地址 (需要公网可访问，用于接收授权回调)
# 用户发送 /auth 后点击授权链接，飞书会重定向到此地址
# 配置后启用用户级 API 能力 (如查看个人任务)
# 注意: 需要在飞书后台「安全设置」中添加此地址为重定向 URL
# FEISHU_OAUTH_REDIRECT_URI=https://your-domain.com/feishu/oauth/callback

# === 飞书工具配置 ===
# 飞书文档/Wiki/多维表格工具总开关 (默认关闭)
FEISHU_TOOLS_ENABLED=false
# 子工具开关 (总开关打开后，以下默认全部启用，设为 false 可单独关闭)
FEISHU_TOOLS_DOC=true
FEISHU_TOOLS_WIKI=true
FEISHU_TOOLS_DRIVE=true
FEISHU_TOOLS_BITABLE=true
FEISHU_TOOLS_CALENDAR=true

# === 聊天上下文配置 ===
# 注入初始上下文时最多拉取的历史消息条数 (默认 10)
# CHAT_HISTORY_MAX_COUNT=10
# 历史上下文总字符上限，超出时从最旧的消息开始丢弃 (默认 4000)
# CHAT_HISTORY_MAX_CHARS=4000

# === 工作区配置 ===
# 自动 clone 的工作区根目录 (默认 DEFAULT_WORK_DIR/.workspaces)
# WORKSPACE_BASE_DIR=
# 自动创建的分支前缀 (默认 feat/claude-session)
# WORKSPACE_BRANCH_PREFIX=feat/claude-session
# bare clone 缓存目录 (setup_workspace 从远程 clone 时使用，默认 DEFAULT_WORK_DIR/.repo-cache)
# REPO_CACHE_DIR=/root/dev/.repo-cache

# === 数据库配置 ===
# 会话数据库路径 (默认 ./data/sessions.db)
# SESSION_DB_PATH=./data/sessions.db
# Pipeline 数据库路径 (默认 ./data/pipelines.db)
# PIPELINE_DB_PATH=./data/pipelines.db

# === 快速确认配置 (Direct 模式) ===
# Direct 回复 bot 时，用小模型先发一条自然短回复（如"好的马上看"），掩盖主流程延迟
# 需要 DASHSCOPE_API_KEY 已配置
# QUICK_ACK_ENABLED=false
# 使用的模型 (DashScope)
# QUICK_ACK_MODEL=qwen3.5-flash
# 超时毫秒数，超时则放弃快速回复 (默认 1500)
# QUICK_ACK_TIMEOUT_MS=1500

# === 定时任务配置 ===
# 定时任务开关 (默认关闭)
# CRON_ENABLED=false
# 定时任务数据库路径 (默认 ./data/cron.db)
# CRON_DB_PATH=./data/cron.db

# === Web 搜索配置 (Tavily) ===
# 替代内置 WebSearch — 当通过 ANTHROPIC_BASE_URL 走代理/网关时，内置 WebSearch（Anthropic 服务端工具）会失效，
# 配置 TAVILY_API_KEY 后会自动启用客户端 web_search MCP 工具。
# Tavily API Key (https://app.tavily.com 获取，形如 tvly-xxx)
# 未配置 key 时 web_search 一律不启用（即使 WEBSEARCH_ENABLED=true 也无效）
# TAVILY_API_KEY=tvly-xxxxxxxx
# 显式开关 (仅在已配 key 时生效：留空=自动启用；设为 false 可强制关闭)
# WEBSEARCH_ENABLED=true
# 默认返回结果数 (1-20，默认 5)
# WEBSEARCH_MAX_RESULTS=5
# 默认搜索深度 basic (1 credit) | advanced (2 credits，默认 basic)
# WEBSEARCH_DEPTH=basic
# 单次请求超时毫秒数 (默认 15000)
# WEBSEARCH_TIMEOUT_MS=15000
# Tavily API base URL (一般无需修改)
# TAVILY_BASE_URL=https://api.tavily.com

# === 记忆系统配置 ===
# 记忆系统总开关 (默认关闭)
# MEMORY_ENABLED=false
# 记忆数据库路径 (默认 ./data/memories.db)
# MEMORY_DB_PATH=./data/memories.db
# DashScope (阿里云百炼) API Key，embedding 和抽取模型共用
# DASHSCOPE_API_KEY=sk-xxxxxxxx
# DashScope OpenAI-compatible base URL
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Embedding 模型 (默认 text-embedding-v4)
# MEMORY_EMBEDDING_MODEL=text-embedding-v4
# Embedding 向量维度 (默认 1536)
# MEMORY_EMBEDDING_DIM=1536
# 记忆抽取模型 (默认 qwen3.5-flash，快速且支持 JSON 结构化输出)
# MEMORY_EXTRACTION_MODEL=qwen3.5-flash
# 混合检索向量权重 (默认 0.7，BM25 权重 = 1 - 此值)
# MEMORY_VECTOR_WEIGHT=0.7
# 注入记忆最大 token 数 (默认 4000，约 20-30 条记忆)
# MEMORY_MAX_INJECT_TOKENS=4000

# === Onboarding ===
# 首次配置完成标记 (npm run onboard 完成后自动写入，无需手动配置)
# ONBOARDING_COMPLETED=true

# === Agent 配置 ===
# Agent 配置文件路径 (默认 ./config/agents.json)
# 首次使用: cp config/agents.example.json config/agents.json 然后自定义
# 无配置文件时自动使用内置 dev agent 兜底
# AGENT_CONFIG_PATH=./config/agents.json


# === 服务配置 ===
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
# 日志文件目录 (默认 ./logs)
LOG_DIR=./logs
# 日志文件保留天数 (默认 7)
LOG_MAX_DAYS=7
