# === 飞书应用配置 ===
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 事件接收模式 (默认 websocket，推荐):
#   websocket - 长连接，无需公网/域名/HTTPS，SDK 主动连接飞书
#   webhook   - HTTP 回调，需要公网 HTTPS 地址 (生产环境可选)
FEISHU_EVENT_MODE=websocket

# 以下仅 webhook 模式需要，websocket 模式可留空
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFY_TOKEN=

# === 安全配置 ===
# 允许使用的飞书用户 open_id 列表，逗号分隔。为空则允许所有用户
ALLOWED_USER_IDS=

# === Claude Code 配置 ===
# Anthropic API Key (Claude Code 需要)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# 默认工作目录
DEFAULT_WORK_DIR=/home/ubuntu/projects
# 单次执行超时时间(秒)
CLAUDE_TIMEOUT=300

# === 服务配置 ===
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
