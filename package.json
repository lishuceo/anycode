{
  "name": "feishu-claude-bridge",
  "version": "0.1.0",
  "description": "通过飞书对话控制 Linux 服务器上的 Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:lint": "npx markdownlint-cli2",
    "docs:lint:fix": "npx markdownlint-cli2 --fix",
    "docs:check-links": "node scripts/docs-link-audit.mjs",
    "docs:spellcheck": "bash scripts/docs-spellcheck.sh",
    "docs:spellcheck:fix": "bash scripts/docs-spellcheck.sh --write",
    "docs:check": "npm run docs:lint && npm run docs:check-links",
    "docs:list": "node scripts/docs-list.mjs"
  },
  "keywords": [
    "feishu",
    "lark",
    "claude-code",
    "ai",
    "bridge"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.45",
    "@larksuiteoapi/node-sdk": "^1.40.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.4.0",
    "eslint": "^10.0.2",
    "express": "^4.21.0",
    "openai": "^6.25.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "sqlite-vec": "^0.1.7-alpha.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
